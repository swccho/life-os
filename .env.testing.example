# Copy to `.env.testing` if you prefer file-based overrides instead of phpunit.xml DB vars.
# PHPUnit sets MySQL + `lifeos_testing` in phpunit.xml by default (see README).

APP_NAME=LifeOS
APP_ENV=testing
APP_KEY=
APP_DEBUG=true

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lifeos_testing
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
