					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Morning walk (v2)\",\n  \"is_active\": true\n}"
						},
						"url": "{{baseUrl}}/api/habits/{{habitId}}"
					}
				},
				{
					"name": "Delete habit",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{baseUrl}}/api/habits/{{habitId}}"
					}
				},
				{
					"name": "List habit logs",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{baseUrl}}/api/habits/{{habitId}}/logs?page=1",
						"description": "Paginated. Unique per habit + logged_date."
					}
				},
				{
					"name": "Create habit log",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"logged_date\": \"2026-03-20\",\n  \"count\": 1,\n  \"notes\": null\n}"
						},
						"url": "{{baseUrl}}/api/habits/{{habitId}}/logs"
					}
				},
				{
					"name": "Delete habit log",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{baseUrl}}/api/habit-logs/{{habitLogId}}"
					}
				}
			]
		},
		{
			"name": "Journal",
			"item": [
				{
					"name": "List journal entries",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{baseUrl}}/api/journal-entries?entry_date=2026-03-15&from=2026-03-01&to=2026-03-31&page=1",
						"description": "Optional filters: `entry_date`, `from`, `to`. Paginated."
					}
				},
				{
					"name": "Create journal entry",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Today\",\n  \"content\": \"Reflection...\",\n  \"entry_date\": \"2026-03-20\"\n}"
						},
						"url": "{{baseUrl}}/api/journal-entries"
					}
				},
				{
					"name": "Get journal entry",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{baseUrl}}/api/journal-entries/{{journalEntryId}}"
					}
				},
				{
					"name": "Update journal entry",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Today (edited)\",\n  \"content\": \"Updated text\"\n}"
						},
						"url": "{{baseUrl}}/api/journal-entries/{{journalEntryId}}"
					}
				},
				{
					"name": "Delete journal entry",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{baseUrl}}/api/journal-entries/{{journalEntryId}}"
					}
				}
			]
		},
		{
			"name": "Mood",
			"item": [
				{
					"name": "List mood entries",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{baseUrl}}/api/mood-entries?entry_date=2026-03-20&from=2026-03-01&to=2026-03-31&page=1",
						"description": "One entry per user per `entry_date` (unique). Paginated."
					}
				},
				{
					"name": "Create mood entry",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"mood_score\": 4,\n  \"mood_label\": \"calm\",\n  \"notes\": null,\n  \"entry_date\": \"2026-03-20\"\n}"
						},
						"url": "{{baseUrl}}/api/mood-entries",
						"description": "`mood_score`: 1–5"
					}
				},
				{
