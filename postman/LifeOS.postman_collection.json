							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Morning walk\",\n  \"description\": \"30 min\",\n  \"frequency_type\": \"daily\",\n  \"target_count\": 1,\n  \"is_active\": true\n}"
						},
						"url": "{{baseUrl}}/api/habits",
						"description": "`frequency_type`: daily | weekly"
					}
				},
				{
					"name": "Get habit",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{baseUrl}}/api/habits/{{habitId}}"
